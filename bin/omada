#!/usr/bin/env python3
"""Zero-install launcher: runs the CLI straight from the repo without pip.

Symlink this onto your PATH (e.g. ~/.local/bin/omada) and it Just Works.
"""
import os
import sys

sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.realpath(__file__))))
from omada_cli.cli import main  # noqa: E402

if __name__ == "__main__":
    sys.exit(main())
